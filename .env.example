# Database
DB_URL=postgresql://postgres:2713@localhost:5432/wastemanagement

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# M-PESA (Safaricom Daraja API)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_key_here
MPESA_CONSUMER_SECRET=your_secret_here
MPESA_SHORTCODE=your_shortcode_here
MPESA_PASSKEY=your_passkey_here
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/callback

# M-PESA B2C (collector payouts)
MPESA_B2C_INITIATOR_NAME=your_initiator_name_here
MPESA_B2C_SECURITY_CREDENTIAL=your_security_credential_here
MPESA_B2C_SHORTCODE=your_b2c_shortcode_here
MPESA_B2C_TIMEOUT_URL=https://yourdomain.com/api/payments/b2c/timeout
MPESA_B2C_RESULT_URL=https://yourdomain.com/api/payments/b2c/result

# Africa's Talking (USSD & SMS)
AT_API_KEY=your_africastalking_key_here
AT_USERNAME=sandbox

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
